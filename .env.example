# ===== 1. App 기본 설정 =====
APP_ENV=local
APP_NAME=rnd-strategy-agent

# ===== 2. 기본 실행 대상 =====
DEFAULT_QUERY=HBM4 기술 동향과 경쟁사 분석
DEFAULT_TECHS=HBM4
DEFAULT_COMPETITOR_COUNT=2

# ===== 3. 경로 설정 =====
BASE_PATH=.
DATA_ROOT=./data
OUTPUT_ROOT=./outputs
PROMPT_ROOT=./prompts

# ===== 4. LangSmith 기본 설정 =====
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=rnd-strategy-agent

# ===== 5. LLM 설정 =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ===== 6. Embedding 설정 (오픈소스) =====
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ===== 7. RAG 최소 설정 =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# ===== 8. LLM API Key =====
OPENAI_API_KEY=

# ===== 9. LangSmith 연결 설정 =====
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=Rnd-Strategy-Agent


TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TOPIC=news
WEB_SEARCH_TIME_RANGE=month
# ===== 10. 평가 기준 (MVP 최소 세트) =====
FRESHNESS_MONTHS=6
MIN_FRESHNESS_RATIO=0.7
MIN_EVIDENCE_COVERAGE=0.9
MIN_COMPETITOR_COUNT=2
MIN_RETRIEVAL_HITRATE_AT_5=0.7
MIN_RETRIEVAL_MRR=0.5

# ===== 11. 제어 전략 (MVP 최소 세트) =====
MAX_QUERY_RETRY=2
MAX_COMPETITOR_RETRY=2
MAX_RETRIEVAL_RETRY=2
MAX_VALIDATION_RETRY=2